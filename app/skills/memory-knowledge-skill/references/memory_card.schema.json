{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://indepth.local/schema/memory_card.schema.json",
  "title": "MemoryCard",
  "description": "Lightweight system memory card used by the current V1 runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "recall_hint",
    "content"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mem_[a-z0-9_\\-]{4,128}$",
      "description": "Stable memory id."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "recall_hint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220,
      "description": "Short high-signal hint used for lightweight recall injection."
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Full memory content stored for later full-card retrieval."
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "archived"],
      "default": "active"
    },
    "updated_at": {
      "type": "string",
      "description": "Managed by the store at write time."
    },
    "expire_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "Optional expiration date in YYYY-MM-DD."
    }
  }
}
