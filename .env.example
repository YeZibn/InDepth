LLM_MODEL_ID=
LLM_MODEL_MINI_ID=
LLM_API_KEY=
LLM_BASE_URL=

# Optional: dedicated embedding provider for system memory vector recall.
LLM_EMBEDDING_MODEL_ID=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_BASE_URL=

# Enable system memory vector recall.
ENABLE_SYSTEM_MEMORY_VECTOR_RECALL=false

# Milvus connection.
SYSTEM_MEMORY_MILVUS_URI=http://127.0.0.1:19530
SYSTEM_MEMORY_MILVUS_TOKEN=
SYSTEM_MEMORY_MILVUS_COLLECTION=system_memory_card_embedding

# Vector recall tuning.
SYSTEM_MEMORY_EMBEDDING_DIM=1536
SYSTEM_MEMORY_VECTOR_TOP_N=10
SYSTEM_MEMORY_RECALL_TOP_K=5
SYSTEM_MEMORY_RECALL_MIN_SCORE=0.65
