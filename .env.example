ENABLE_SYSTEM_MEMORY_VECTOR_RECALL=false
LLM_EMBEDDING_MODEL_ID=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_BASE_URL=
SYSTEM_MEMORY_MILVUS_URI=http://127.0.0.1:19530
SYSTEM_MEMORY_EMBEDDING_DIM=1536
